rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userStats/{userId} {
      // Allow anyone to read userStats for leaderboard purposes
      allow read: if true;
      // Only allow users to write their own stats
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /userDaily/{userId} {
      // Only allow users to read their own daily game state
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only allow users to write their own daily game state
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
